{
	"name": "fleet",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "pnpm@11.11.0",
	"scripts": {
		"api": "tsx server/index.ts",
		"api:start": "tsx server/index.ts",
		"db:deploy": "prisma migrate deploy",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:reset": "prisma migrate reset",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio",
		"db:up": "docker compose up -d",
		"dev": "vite",
		"build": "tsc -b && tsc -p tsconfig.server.json && vite build",
		"preview": "vite preview",
		"test:api": "node --import tsx --test server/*.test.ts",
		"typecheck": "tsc -b && tsc -p tsconfig.server.json"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@supabase/supabase-js": "^2.110.7",
		"@tanstack/react-query": "^5.92.0",
		"@tanstack/react-table": "^8.21.3",
		"dotenv": "^17.4.2",
		"lucide-react": "^0.562.0",
		"pg": "^8.22.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.11.0",
		"tsx": "^4.22.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.3",
		"prisma": "^7.8.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
