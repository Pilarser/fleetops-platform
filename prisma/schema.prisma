// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String    @id
  name      String
  users     User[]
  drivers   Driver[]
  vehicles  Vehicle[]
  services  MobilityService[]
  providers ProviderLocation[]
  transactions FleetTransaction[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id        String   @id
  companyId String
  name      String
  email     String   @unique
  password  String
  role      String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Driver {
  id            String   @id
  companyId     String
  vehicleId     String?
  name          String
  email         String
  status        String
  costCenter    String
  monthlySpend  Float
  personalSpend Float
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, vehicleId])
}

model Vehicle {
  id           String   @id
  companyId    String
  plate        String
  make         String
  model        String
  fuelType     String
  status       String
  costCenter   String
  monthlySpend Float
  mileageKm    Int
  company      Company  @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MobilityService {
  id               String   @id
  companyId        String
  name             String
  description      String
  enabled          Boolean
  monthlyLimit     Float
  requiresApproval Boolean
  company          Company  @relation(fields: [companyId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProviderLocation {
  id         String   @id
  companyId  String
  name       String
  service    String
  address    String
  city       String
  distanceKm Float
  status     String
  company    Company  @relation(fields: [companyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FleetTransaction {
  id          String   @id
  companyId   String
  date        String
  driverId    String
  vehicleId   String
  service     String
  provider    String
  amount      Float
  vat         Float
  status      String
  expenseType String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
